{
  "name": "sol-cli",
  "version": "0.1.0",
  "description": "Solana CLI for Humans and LLM Agents",
  "type": "module",
  "bin": {
    "sol": "./bin/sol.mjs"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "bun build --compile src/index.ts --outfile sol",
    "test": "node --import tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@solana/kit": "^2.1.0",
    "@solana-program/token": "^0.5.0",
    "@solana-program/system": "^0.7.0",
    "better-sqlite3": "^11.0.0",
    "commander": "^14.0.0",
    "smol-toml": "^1.3.1",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin/",
    "src/"
  ],
  "license": "MIT"
}
